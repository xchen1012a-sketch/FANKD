.tabbar-safe {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  padding: 0 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  pointer-events: none;
}

.tabbar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 116rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 -10rpx 34rpx rgba(36, 87, 122, 0.12);
  pointer-events: auto;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 96rpx;
  color: #5f7182;
  font-size: 21rpx;
  font-weight: 700;
}

.icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 4rpx;
  border-radius: 18rpx;
  transition: background 0.16s ease;
}

.is-active {
  color: #18724f;
}

.is-active .icon-wrap {
  background: rgba(53, 183, 121, 0.14);
}

.tab-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  box-sizing: border-box;
  color: currentColor;
}

.tab-icon.home::before {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 8rpx;
  width: 20rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 4rpx;
}

.tab-icon.home::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 3rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  transform: rotate(45deg);
  border-radius: 3rpx;
}

.tab-icon.grid::before,
.tab-icon.grid::after {
  content: "";
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border: 4rpx solid currentColor;
  border-radius: 5rpx;
}

.tab-icon.grid::before {
  left: 0;
  top: 0;
  box-shadow: 18rpx 0 0 -4rpx transparent, 18rpx 0 0 0 currentColor;
}

.tab-icon.grid::after {
  left: 0;
  bottom: 0;
  box-shadow: 18rpx 0 0 -4rpx transparent, 18rpx 0 0 0 currentColor;
}

.tab-icon.plus::before,
.tab-icon.plus::after {
  content: "";
  position: absolute;
  left: 3rpx;
  top: 13rpx;
  width: 24rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tab-icon.plus::after {
  transform: rotate(90deg);
}

.tab-icon.user::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 2rpx;
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.tab-icon.user::after {
  content: "";
  position: absolute;
  left: 3rpx;
  bottom: 0;
  width: 24rpx;
  height: 12rpx;
  border: 4rpx solid currentColor;
  border-radius: 18rpx 18rpx 6rpx 6rpx;
}
